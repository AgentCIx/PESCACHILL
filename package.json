{
  "name": "black-monastery-tracker",
  "version": "1.0.0",
  "description": "Tracker de profit para pesca en Albion Online",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Tu Nombre",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.tudominio.blackmonastery",
    "productName": "Black Monastery Tracker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "AgentCix",
      "repo": "PESCACHILL"
    }
  }
}
